<?xml version="1.0"?>
<robot name = "enwbot" xmlns:xacro="http://www.ros.org/wiki/xacro">
    <ros2_control name="enwbot" type="system">
        <hardware>
            <plugin>ethercat_driver/EthercatDriver</plugin>
            <param name="master_id">0</param>
            <param name="control_frequency">200</param>
            <param name="transfer_config">$(find enwbot_description)/config/enwbot_fsoe_config.yaml</param>
        </hardware>

        <gpio name="ek1914">
            <ec_module name="ek1914_01">
                <plugin>ethercat_generic_plugins/GenericEcSlave</plugin>
                <param name="alias">0</param>
                <param name="position">0</param>
                <param name="slave_config">$(find enwbot_description)/config/beckhoff_ek1914.yaml</param>
            </ec_module>
        </gpio>

        <gpio name="el1918">
            <state_interface name="safety_logic_state" />
            <state_interface name="safety_output_vars" />
            <command_interface name="safety_input_vars" />
            <ec_module name="el1918_01">
                <plugin>ethercat_generic_plugins/GenericEcSlave</plugin>
                <param name="alias">0</param>
                <param name="position">2</param>
                <param name="slave_config">$(find enwbot_description)/config/beckhoff_el1918.yaml</param>
            </ec_module>
        </gpio>

        <joint name="right_wheel_joint">
            <command_interface name="control_word" />
            <command_interface name="position" />
            <command_interface name="velocity" />
            <command_interface name="mode_of_operation" />
            <command_interface name="reset_fault"/>
            <state_interface name="control_word" />
            <state_interface name="position" />
            <state_interface name="velocity" />
            <state_interface name="status_word" />
            <state_interface name="mode_of_operation" />
            <state_interface name="sto_cmd_state" />
            <state_interface name="ss1_cmd_state" />
            <state_interface name="safe_inputs" />
            <state_interface name="reset_fault"/>
            <ec_module name="novanta_01">
                <plugin>ethercat_generic_plugins/EcCiA402Drive</plugin>
                <param name="alias">0</param>
                <param name="position">0</param>
                <!-- Available modes of operation = position 8, velocity 9, effort 10, homing 6 -->
                <param name="mode_of_operation">9</param>
                <!-- Novanta  -->
                <param name="slave_config">$(find enwbot_description)/config/novanta_safe.yaml</param>
            </ec_module>
        </joint>

    </ros2_control>
</robot>